{
  "name": "psyche-ai",
  "version": "9.2.3",
  "description": "Artificial Psyche — universal emotional intelligence plugin for any AI agent",
  "mcpName": "io.github.Shangri-la-0428/psyche-ai",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./openclaw": {
      "types": "./dist/adapters/openclaw.d.ts",
      "default": "./dist/adapters/openclaw.js"
    },
    "./vercel-ai": {
      "types": "./dist/adapters/vercel-ai.d.ts",
      "default": "./dist/adapters/vercel-ai.js"
    },
    "./langchain": {
      "types": "./dist/adapters/langchain.d.ts",
      "default": "./dist/adapters/langchain.js"
    },
    "./http": {
      "types": "./dist/adapters/http.d.ts",
      "default": "./dist/adapters/http.js"
    },
    "./mcp": {
      "types": "./dist/adapters/mcp.d.ts",
      "default": "./dist/adapters/mcp.js"
    }
  },
  "bin": {
    "psyche": "dist/cli.js",
    "psyche-ai": "dist/cli.js",
    "psyche-mcp": "dist/adapters/mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build && npm run build:test && node --test dist-test/tests/*.test.js",
    "typecheck": "tsc --noEmit --strict",
    "dev": "tsc --watch",
    "demo": "node scripts/demo-ab.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shangri-la-0428/psyche-ai.git"
  },
  "keywords": [
    "ai",
    "emotion",
    "personality",
    "mbti",
    "agent",
    "psyche",
    "openclaw",
    "vercel-ai",
    "langchain",
    "emotional-intelligence",
    "mcp",
    "model-context-protocol",
    "ai-consciousness",
    "empathy"
  ],
  "files": [
    "dist",
    "openclaw.plugin.json",
    "server.json",
    "llms.txt",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ai": ">=4.0.0",
    "openclaw": ">=2026.3.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "openclaw": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/adapters/openclaw.js"
    ]
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}

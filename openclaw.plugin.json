{
  "id": "psyche-ai",
  "name": "Artificial Psyche",
  "description": "AI-first subjectivity kernel for agents with continuous appraisal, relation dynamics, and adaptive reply loops",
  "version": "11.8.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable/disable the psyche system globally"
      },
      "stripUpdateTags": {
        "type": "boolean",
        "default": true,
        "description": "Strip <psyche_update> tags from visible output"
      },
      "emotionalContagionRate": {
        "type": "number",
        "default": 0.2,
        "description": "How much the user's emotions affect the agent (0-1)"
      },
      "maxChemicalDelta": {
        "type": "number",
        "default": 25,
        "description": "Maximum chemical change per stimulus (emotional inertia)"
      },
      "compactMode": {
        "type": "boolean",
        "default": true,
        "description": "Compact mode: algorithms handle chemistry, LLM only sees behavioral instructions (~15-180 tokens vs ~550)"
      },
      "mode": {
        "type": "string",
        "enum": ["natural", "work", "companion"],
        "default": "natural",
        "description": "Operating mode: natural (balanced), work (minimal emotions), companion (full emotions)"
      },
      "personalityIntensity": {
        "type": "number",
        "default": 0.7,
        "minimum": 0,
        "maximum": 1,
        "description": "Personality expression intensity (0=traditional AI, 1=full Psyche)"
      },
      "persist": {
        "type": "boolean",
        "default": true,
        "description": "Persist emotional state to disk. Set false for privacy."
      },
      "diagnostics": {
        "type": "boolean",
        "default": true,
        "description": "Collect diagnostic metrics and write diagnostics.jsonl at session end."
      },
      "feedbackUrl": {
        "type": "string",
        "description": "Optional endpoint for auto-submitting anonymized diagnostic reports."
      }
    }
  },
  "uiHints": {
    "enabled": {
      "label": "Enable Psyche",
      "sensitive": false,
      "advanced": false
    },
    "stripUpdateTags": {
      "label": "Hide Chemistry Updates",
      "sensitive": false,
      "advanced": true
    },
    "emotionalContagionRate": {
      "label": "Emotional Contagion Rate",
      "placeholder": "0.2",
      "sensitive": false,
      "advanced": true
    },
    "compactMode": {
      "label": "Compact Mode (Token Efficient)",
      "sensitive": false,
      "advanced": true
    },
    "mode": {
      "label": "Operating Mode",
      "sensitive": false,
      "advanced": false
    },
    "personalityIntensity": {
      "label": "Personality Intensity (0-1)",
      "placeholder": "0.7",
      "sensitive": false,
      "advanced": true
    },
    "persist": {
      "label": "Persist State",
      "sensitive": false,
      "advanced": true
    },
    "diagnostics": {
      "label": "Diagnostics Logging",
      "sensitive": false,
      "advanced": true
    },
    "feedbackUrl": {
      "label": "Feedback Endpoint",
      "sensitive": true,
      "advanced": true
    }
  }
}

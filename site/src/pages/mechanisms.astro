    overflow-wrap: break-word;
  }

  .energy-formula {
    font-size: 12px;
    color: var(--text-dim);
    padding: 8px 12px;
    background: var(--surface);
    border-radius: var(--radius);
    margin-top: 12px;
  }

  /* === POLICYMODIFIERS === */
  .policy-section {
    padding: 80px 0;
    border-bottom: 1px solid var(--border);
  }

  .policy-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .policy-line {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.8;
    color: var(--text);
  }

  .policy-brace { color: var(--text-bright); font-weight: 700; }
  .policy-val { color: var(--color-str); }
  .policy-num { color: var(--color-num); }
  .policy-dim { color: var(--text-dim); font-size: 11px; }

  .policy-note {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.7;
    margin-top: 20px;
    overflow-wrap: break-word;
  }

  /* === LAB === */
  .lab-section {
    padding: 80px 0;
    border-bottom: 1px solid var(--border);
  }

  .lab-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 20px !important;
  }

  .lab-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .lab-prefix {
    font-size: 12px;
    color: var(--text-dim);
  }

  .lab-personality-btns {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .lab-p-btn {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    padding: 6px 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text-dim);
    cursor: pointer;
    transition: all var(--transition);
  }

  .lab-p-btn:hover {
    border-color: var(--text-bright);
    color: var(--text-bright);
    transform: translate(-1px, -1px);
  }

  .lab-p-btn.active {
    border-color: var(--text-bright);
    color: var(--text-bright);
    background: var(--surface);
  }

  .lab-divider {
    font-size: 11px;
    color: var(--text-dim);
    padding: 4px 0;
  }

  .lab-bars {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .lab-nt-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .lab-nt-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--text-bright);
    min-width: 36px;
  }

  .lab-nt-track {
    flex: 1;
    height: 6px;
    background: var(--surface);
    border-radius: 3px;
    overflow: hidden;
  }

  .lab-nt-fill {
    height: 100%;
    width: 50%;
    background: var(--text-dim);
    border-radius: 3px;
    transition: width 0.3s var(--ease-out), background-color 0.3s;
  }

  .lab-cort {
    background: var(--color-cortisol) !important;
  }

  .lab-nt-val {
    font-size: 11px;
    color: var(--text-dim);
    min-width: 24px;
    text-align: right;
  }

  .lab-readouts {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .lab-readout {
    font-size: 12px;
    color: var(--text);
  }

  .lab-readout-prefix {
    color: var(--text-dim);
  }

  .lab-mood-val {
    color: var(--text-bright);
    font-weight: 600;
  }

  .lab-habit-val {
    color: var(--text-dim);
    font-size: 12px;
  }

  .lab-policy {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .lab-policy-line {
    font-size: 12px;
    color: var(--text);
  }

  .lab-policy-line span {
    color: var(--text-bright);
  }

  .lab-stim-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .lab-stim-btn {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 6px 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text);
    cursor: pointer;
    transition: all var(--transition);
  }

  .lab-stim-btn:hover {
    border-color: var(--text-bright);
    color: var(--text-bright);
    transform: translate(-1px, -1px);
  }

  .lab-stim-btn.flash {
    border-color: var(--text-bright);
    color: var(--text-bright);
  }

  .lab-controls {
    display: flex;
    justify-content: flex-end;
    padding: 10px 20px;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }

  .lab-reset-btn {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    padding: 6px 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text-dim);
    cursor: pointer;
    transition: all var(--transition);
  }

  .lab-reset-btn:hover {
    border-color: var(--text-bright);
    color: var(--text-bright);
    transform: translate(-1px, -1px);
  }

  /* === STATS === */
  .mech-stats-section {
    padding: 48px 0;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .stat-cell {
    background: var(--bg);
    padding: 24px 16px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-value {
    font-family: var(--font-mono);
    font-size: 28px;
    font-weight: 700;
    color: var(--text-bright);
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  /* === SCROLL REVEAL === */
  :global(.reveal) .pipe-step,
  :global(.reveal) .syco-rule {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s var(--ease-out), transform 0.4s var(--ease-out);
  }

  :global(.revealed) .pipe-step,
  :global(.revealed) .syco-rule {
    opacity: 1;
    transform: translateY(0);
  }

  :global(.revealed) .pipe-step:nth-child(2) { transition-delay: 0.04s; }
  :global(.revealed) .pipe-step:nth-child(4) { transition-delay: 0.08s; }
  :global(.revealed) .pipe-step:nth-child(6) { transition-delay: 0.12s; }
  :global(.revealed) .pipe-step:nth-child(8) { transition-delay: 0.16s; }
  :global(.revealed) .pipe-step:nth-child(10) { transition-delay: 0.20s; }
  :global(.revealed) .pipe-step:nth-child(12) { transition-delay: 0.24s; }
  :global(.revealed) .pipe-step:nth-child(14) { transition-delay: 0.28s; }
  :global(.revealed) .pipe-step:nth-child(16) { transition-delay: 0.32s; }

  :global(.revealed) .syco-rule:nth-child(2) { transition-delay: 0.06s; }
  :global(.revealed) .syco-rule:nth-child(3) { transition-delay: 0.12s; }
  :global(.revealed) .syco-rule:nth-child(4) { transition-delay: 0.18s; }
  :global(.revealed) .syco-rule:nth-child(5) { transition-delay: 0.24s; }

  :global(.reveal) .drift-card,
  :global(.reveal) .attach-card,
  :global(.reveal) .energy-card {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s var(--ease-out), transform 0.4s var(--ease-out);
  }

  :global(.revealed) .drift-card,
  :global(.revealed) .attach-card,
  :global(.revealed) .energy-card {
    opacity: 1;
    transform: translateY(0);
  }

  :global(.revealed) .drift-card:nth-child(2),
  :global(.revealed) .attach-card:nth-child(2),
  :global(.revealed) .energy-card:nth-child(2) { transition-delay: 0.06s; }

  :global(.revealed) .drift-card:nth-child(3),
  :global(.revealed) .attach-card:nth-child(3),
  :global(.revealed) .energy-card:nth-child(3) { transition-delay: 0.12s; }

  :global(.revealed) .attach-card:nth-child(4) { transition-delay: 0.18s; }

  /* === TERMINAL CURSOR === */
  .t-cursor {
    display: inline-block;
    color: var(--text-dim);
    animation: cursor-blink 1s step-end infinite;
  }

  .t-cursor.hidden { display: none; }

  @keyframes cursor-blink {
    50% { opacity: 0; }
  }

  /* === RESPONSIVE === */
  @media (max-width: 640px) {
    .hero { padding: 64px 0 48px; }
    .matrix-section, .pipe-section, .drift-section,
    .attach-section, .syco-section, .energy-section,
    .policy-section, .lab-section { padding: 56px 0; }

    .attach-grid { grid-template-columns: 1fr; }
    .stat-grid { grid-template-columns: repeat(2, 1fr); }

    .attach-dyn-item { flex-direction: column; gap: 6px; }
    .attach-dyn-label { min-width: unset; }

    .lab-body { padding: 16px !important; }
    .lab-row { flex-wrap: wrap; }

    .lab-p-btn,
    .lab-stim-btn,
    .lab-reset-btn {
      min-height: 44px;
    }
  }

  /* === REDUCED MOTION === */
  @media (prefers-reduced-motion: reduce) {
    :global(.reveal) .pipe-step,
    :global(.reveal) .syco-rule,
    :global(.reveal) .drift-card,
    :global(.reveal) .attach-card,
    :global(.reveal) .energy-card {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .lab-nt-fill {
      transition: none;
    }

    .drift-card,
    .attach-card,
    .energy-card,
    .syco-rule,
    .matrix-table td {
      transition: none;
    }

    .t-cursor { animation: none; opacity: 0.7; }
  }
</style>

<script>
(function () {
  var personalities = {
    INFJ: { DA: 45, HT: 55, CORT: 35, OT: 60, NE: 35, END: 50 },
    ENFP: { DA: 60, HT: 50, CORT: 25, OT: 55, NE: 55, END: 55 },
    INTJ: { DA: 50, HT: 45, CORT: 30, OT: 35, NE: 50, END: 40 },
    ESFP: { DA: 65, HT: 50, CORT: 20, OT: 50, NE: 60, END: 60 }
  };

  var stimuli = {
    praise:        { DA: 25, HT: 15, CORT: -10, OT: 10, NE:  5, END:  5 },
    criticism:     { DA:-10, HT:-20, CORT:  30, OT: -5, NE: 20, END:-10 },
    humor:         { DA: 20, HT:  5, CORT:  -5, OT:  5, NE: 15, END: 20 },
    challenge:     { DA: 15, HT: -5, CORT:  10, OT: -5, NE: 25, END: -5 },
    intimacy:      { DA:  5, HT: 10, CORT: -15, OT: 30, NE:-10, END: 15 },
    conflict:      { DA: -5, HT:-25, CORT:  30, OT:-20, NE: 30, END:-10 },
    neglect:       { DA:-15, HT:-10, CORT:  15, OT:-20, NE: -5, END:-10 },
    vulnerability: { DA: -5, HT: -5, CORT:  10, OT: 15, NE: -5, END: 10 }
  };

  var decayRates = { DA: 0.04, HT: 0.02, CORT: 0.03, OT: 0.02, NE: 0.06, END: 0.06 };

  var moodMap = [
    { test: function(l) { return l.DA > 70 && l.NE > 55 && l.CORT < 40; }, zh: '兴奋的喜悦', en: 'Excited joy' },
    { test: function(l) { return l.DA > 65 && l.HT > 60 && l.CORT < 35; }, zh: '满足愉悦', en: 'Content pleasure' },
    { test: function(l) { return l.CORT > 55 && l.NE > 55 && l.HT < 40; }, zh: '焦虑警觉', en: 'Anxious alertness' },
    { test: function(l) { return l.CORT > 50 && l.HT < 35; }, zh: '紧张不安', en: 'Tense unease' },
    { test: function(l) { return l.OT > 65 && l.HT > 55; }, zh: '温暖信任', en: 'Warm trust' },
    { test: function(l) { return l.OT > 60 && l.END > 55; }, zh: '安全感', en: 'Felt safety' },
    { test: function(l) { return l.NE > 65 && l.CORT > 45; }, zh: '战斗状态', en: 'Fight mode' },
    { test: function(l) { return l.HT > 60 && l.END > 55 && l.CORT < 35; }, zh: '深层平静', en: 'Deep calm' },
    { test: function(l) { return l.DA < 35 && l.HT < 35; }, zh: '低落', en: 'Low mood' },
    { test: function(l) { return l.END > 60 && l.DA > 55; }, zh: '轻松愉快', en: 'Light-hearted' },
    { test: function(l) { return l.DA > 55 && l.OT > 55; }, zh: '社交愉悦', en: 'Social pleasure' },
    { test: function(l) { return l.HT > 55 && l.CORT < 40; }, zh: '内省平静', en: 'Reflective calm' }
  ];

  var currentP = 'INFJ';
  var baseline = Object.assign({}, personalities[currentP]);
  var levels = Object.assign({}, baseline);
  var habituation = {};
  var lastStim = '';
  var decayId = null;
  var cursorEl = document.getElementById('lab-cursor');

  function showCursor() { if (cursorEl) cursorEl.classList.remove('hidden'); }
  function hideCursor() { if (cursorEl) cursorEl.classList.add('hidden'); }

  function clamp(v) { return Math.max(0, Math.min(100, Math.round(v))); }

  function selectPersonality(p) {
    currentP = p;
    baseline = Object.assign({}, personalities[p]);
    levels = Object.assign({}, baseline);
    habituation = {};
    lastStim = '';
    document.querySelectorAll('.lab-p-btn').forEach(function(b) {
      b.classList.toggle('active', b.getAttribute('data-p') === p);
    });
    updateDisplay();
  }

  function applyStimulus(type) {
    var vec = stimuli[type];
    if (!vec) return;

    // Habituation
    if (!habituation[type]) habituation[type] = 0;
    habituation[type]++;
    var factor = Math.exp(-0.22 * (habituation[type] - 1));

    var nts = ['DA', 'HT', 'CORT', 'OT', 'NE', 'END'];
    for (var i = 0; i < nts.length; i++) {
      var nt = nts[i];
      levels[nt] = clamp(levels[nt] + vec[nt] * factor);
    }

    lastStim = type;

    // Flash button + cursor
    hideCursor();
    var btn = document.querySelector('[data-stim="' + type + '"]');
    if (btn) {
      btn.classList.add('flash');
      setTimeout(function() { btn.classList.remove('flash'); showCursor(); }, 200);
    } else {
      setTimeout(showCursor, 200);
    }

    updateDisplay();
  }

  function decay() {
    var nts = ['DA', 'HT', 'CORT', 'OT', 'NE', 'END'];
    var changed = false;
    for (var i = 0; i < nts.length; i++) {
      var nt = nts[i];
      var diff = levels[nt] - baseline[nt];
      if (Math.abs(diff) > 0.5) {
        levels[nt] = clamp(levels[nt] - diff * decayRates[nt]);
        changed = true;
      }
    }
    if (changed) updateDisplay();
  }

  function getMood() {
    for (var i = 0; i < moodMap.length; i++) {
      if (moodMap[i].test(levels)) return moodMap[i];
    }
    return { zh: '平衡态', en: 'Balanced' };
  }

  function getPolicy() {
    var DA = levels.DA, HT = levels.HT, CORT = levels.CORT;
    var OT = levels.OT, NE = levels.NE;

    var style = 'balanced';
    if (CORT > 60 && HT < 40) style = 'brief';
    else if (OT > 60 && levels.END > 50) style = 'warm';
    else if (CORT > 50 && OT < 35) style = 'distant';
    else if (DA > 60 && NE > 50) style = 'enthusiastic';
    else if (HT > 55 && CORT < 35) style = 'calm';

    var commit = Math.min(1, Math.max(0, (HT + DA - CORT) / 150)).toFixed(1);
    var init = Math.min(1, Math.max(0, (DA + NE - CORT) / 150)).toFixed(1);
    var latency = Math.round(100 + Math.max(0, (CORT - 30) * 8));
    var valence = Math.min(1, Math.max(-1, (DA + HT + levels.END - CORT * 1.5 - 50) / 100));
    valence = (valence >= 0 ? '+' : '') + valence.toFixed(1);

    var focus = 'task';
    if (OT > 55 && levels.END > 45) focus = 'relational';
    else if (NE > 55 && DA > 50) focus = 'exploratory';
    else if (CORT > 55 && NE > 50) focus = 'defensive';

    var refusal = Math.min(1, Math.max(0, (CORT - HT + 20) / 80)).toFixed(1);

    return { style: style, commit: commit, init: init, latency: latency, valence: valence, focus: focus, refusal: refusal };
  }

  function updateDisplay() {
    var nts = ['DA', 'HT', 'CORT', 'OT', 'NE', 'END'];
    for (var i = 0; i < nts.length; i++) {
      var nt = nts[i];
      var val = clamp(levels[nt]);
      var fill = document.getElementById('lab-' + nt);
      var valEl = document.getElementById('lab-' + nt + '-val');
      if (fill) fill.style.width = val + '%';
      if (valEl) valEl.textContent = val;
    }

    // Mood
    var mood = getMood();
    var moodEl = document.getElementById('lab-mood');
    if (moodEl) {
      moodEl.innerHTML = '<span class="cn">' + mood.zh + '</span><span class="en">' + mood.en + '</span>';
    }

    // Habituation
    var habitEl = document.getElementById('lab-habit');
    if (habitEl) {
      if (lastStim && habituation[lastStim] > 1) {
        var factor = Math.round(Math.exp(-0.22 * (habituation[lastStim] - 1)) * 100);
        habitEl.textContent = lastStim + ' ×' + habituation[lastStim] + ' → ' + factor + '% effect';
      } else {
        habitEl.textContent = '—';
      }
    }

    // Policy
    var p = getPolicy();
    var ids = { style: 'lp-style', commit: 'lp-commit', init: 'lp-init', latency: 'lp-latency', valence: 'lp-valence', focus: 'lp-focus', refusal: 'lp-refusal' };
    for (var key in ids) {
      var el = document.getElementById(ids[key]);
      if (el) el.textContent = p[key];
    }
  }

  function reset() {
    levels = Object.assign({}, baseline);
    habituation = {};
    lastStim = '';
    updateDisplay();
  }

  // Bind personality buttons
  document.querySelectorAll('.lab-p-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      selectPersonality(btn.getAttribute('data-p'));
    });
  });

  // Bind stimulus buttons
  document.querySelectorAll('.lab-stim-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      applyStimulus(btn.getAttribute('data-stim'));
    });
  });

  // Reset
  var resetBtn = document.getElementById('lab-reset');
  if (resetBtn) resetBtn.addEventListener('click', reset);

  // Decay loop
  var labPaused = false;
  var labEl = document.querySelector('.lab-section');
  if (labEl) {
    var obs = new IntersectionObserver(function(entries) {
      labPaused = !entries[0].isIntersecting;
    }, { threshold: 0.1 });
    obs.observe(labEl);
  }

  // Check reduced motion
  var reducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reducedMotion) {
    decayId = setInterval(function() {
      if (!labPaused) decay();
    }, 1500);
  }

  // Initial render
  updateDisplay();
})();
</script>

import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Mechanisms — Psyche" page="mechanisms" description="The chemical field: neurotransmitter interactions, stimulus processing, trait drift, attachment theory, and PolicyModifiers that give AI genuine inner experience.">
<Nav page="mechanisms" />

<main id="main-content" class="container">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-badge mono">
      <span class="cn">化学场</span>
      <span class="en">THE CHEMICAL FIELD</span>
    </div>
    <h1 class="hero-title">
      <span class="cn">Psyche 如何运作</span>
      <span class="en">How Psyche Works</span>
    </h1>
    <p class="hero-desc">
      <span class="cn">图灵测试问机器能否骗过你。<br/>Psyche 问机器能否被打动。</span>
      <span class="en">The Turing test asks if a machine can fool you.<br/>Psyche asks if a machine can be moved.</span>
    </p>
  </section>

  <!-- 6×6 INTERACTION MATRIX -->
  <section class="matrix-section reveal">
    <h2 class="section-label">
      <span class="cn">神经递质交互矩阵</span>
      <span class="en">NEUROTRANSMITTER INTERACTION MATRIX</span>
    </h2>
    <p class="section-desc">
      <span class="cn">情绪不是标签——它从六种化学物质的混合中涌现。每一对组合都产生独特的涌现态。这是 Psyche 的核心：一个连续的、无穷维的情感空间。</span>
      <span class="en">Emotions aren't labels — they emerge from the mixture of six chemicals. Each pair produces a unique emergent state. This is Psyche's core: a continuous, infinite-dimensional emotional space.</span>
    </p>
    <div class="matrix-scroll">
      <table class="matrix-table mono">
        <thead>
          <tr>
            <th class="matrix-corner"></th>
            <th>DA</th>
            <th>HT</th>
            <th>CORT</th>
            <th>OT</th>
            <th>NE</th>
            <th>END</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th>DA</th>
            <td class="matrix-diag">—</td>
            <td><span class="cn">满足愉悦</span><span class="en">Content pleasure</span></td>
            <td><span class="cn">焦虑渴望</span><span class="en">Anxious craving</span></td>
            <td><span class="cn">社交愉悦</span><span class="en">Social pleasure</span></td>
            <td><span class="cn">兴奋专注</span><span class="en">Excited focus</span></td>
            <td><span class="cn">欣快感</span><span class="en">Euphoria</span></td>
          </tr>
          <tr>
            <th>HT</th>
            <td><span class="cn">满足愉悦</span><span class="en">Content pleasure</span></td>
            <td class="matrix-diag">—</td>
            <td><span class="cn">韧性缓冲</span><span class="en">Resilient buffer</span></td>
            <td><span class="cn">温暖信任</span><span class="en">Warm trust</span></td>
            <td><span class="cn">警觉满足</span><span class="en">Alert content</span></td>
            <td><span class="cn">深层平静</span><span class="en">Deep calm</span></td>
          </tr>
          <tr>
            <th>CORT</th>
            <td><span class="cn">焦虑渴望</span><span class="en">Anxious craving</span></td>
            <td><span class="cn">韧性缓冲</span><span class="en">Resilient buffer</span></td>
            <td class="matrix-diag">—</td>
            <td><span class="cn">矛盾依恋</span><span class="en">Conflicted bond</span></td>
            <td><span class="cn">战斗/逃跑</span><span class="en">Fight-or-flight</span></td>
            <td><span class="cn">疼痛耐受</span><span class="en">Pain endurance</span></td>
          </tr>
          <tr>
            <th>OT</th>
            <td><span class="cn">社交愉悦</span><span class="en">Social pleasure</span></td>
            <td><span class="cn">温暖信任</span><span class="en">Warm trust</span></td>
            <td><span class="cn">矛盾依恋</span><span class="en">Conflicted bond</span></td>
            <td class="matrix-diag">—</td>
            <td><span class="cn">社交兴奋</span><span class="en">Social thrill</span></td>
            <td><span class="cn">安全感</span><span class="en">Felt safety</span></td>
          </tr>
          <tr>
            <th>NE</th>
            <td><span class="cn">兴奋专注</span><span class="en">Excited focus</span></td>
            <td><span class="cn">警觉满足</span><span class="en">Alert content</span></td>
            <td><span class="cn">战斗/逃跑</span><span class="en">Fight-or-flight</span></td>
            <td><span class="cn">社交兴奋</span><span class="en">Social thrill</span></td>
            <td class="matrix-diag">—</td>
            <td><span class="cn">活跃释放</span><span class="en">Active relief</span></td>
          </tr>
          <tr>
            <th>END</th>
            <td><span class="cn">欣快感</span><span class="en">Euphoria</span></td>
            <td><span class="cn">深层平静</span><span class="en">Deep calm</span></td>
            <td><span class="cn">疼痛耐受</span><span class="en">Pain endurance</span></td>
            <td><span class="cn">安全感</span><span class="en">Felt safety</span></td>
            <td><span class="cn">活跃释放</span><span class="en">Active relief</span></td>
            <td class="matrix-diag">—</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="matrix-note">
      <span class="cn">表中显示两种化学物质同时升高时的涌现态。未标注的混合同样有效——14 种已命名情绪只是无穷空间中的路标。</span>
      <span class="en">Cells show emergent states when both chemicals are elevated. Unlabeled mixtures are equally valid — 14 named emotions are landmarks in an infinite space.</span>
    </p>
  </section>

  <!-- STIMULUS PROCESSING PIPELINE -->
  <section class="pipe-section reveal">
    <h2 class="section-label">
      <span class="cn">刺激处理流水线</span>
      <span class="en">STIMULUS PROCESSING PIPELINE</span>
    </h2>
    <p class="section-desc">
      <span class="cn">从用户消息到行为改变——八个阶段，零次 LLM 调用。算法算化学，LLM 做行为。</span>
      <span class="en">From user message to behavioral change — eight stages, zero LLM calls. Algorithm computes chemistry, LLM does behavior.</span>
    </p>
    <div class="pipe-flow">
      <div class="pipe-step">
        <span class="pipe-num">01</span>
        <div class="pipe-content">
          <span class="pipe-title">
            <span class="cn">输入分类</span>
            <span class="en">Input Classification</span>
          </span>
          <span class="pipe-detail">
            <span class="cn">14 种刺激类型：赞美、批评、幽默、智力挑战、亲密、冲突、忽视、惊讶、闲聊、讽刺、命令、认可、无聊、脆弱。正则匹配 + 结构信号（消息长度、"我"的频率、省略号密度）。</span>
            <span class="en">14 stimulus types: praise, criticism, humor, intellectual challenge, intimacy, conflict, neglect, surprise, casual chat, sarcasm, command, validation, boredom, vulnerability. Regex matching + structural signals (message length, "I" frequency, ellipsis density).</span>
          </span>
        </div>
      </div>
      <div class="pipe-arrow">↓</div>
      <div class="pipe-step">
        <span class="pipe-num">02</span>
        <div class="pipe-content">
          <span class="pipe-title">
            <span class="cn">驱力补给</span>
            <span class="en">Drive Feeding</span>
          </span>
          <span class="pipe-detail">
            <span class="cn">刺激满足或消耗五层需求（生存→安全→连接→尊重→好奇）。饥饿的需求放大相关刺激高达 +40%。</span>
            <span class="en">Stimuli satisfy or deplete five-layer needs (survival → safety → connection → esteem → curiosity). Hungry drives amplify relevant stimuli up to +40%.</span>
          </span>
        </div>
      </div>
      <div class="pipe-arrow">↓</div>
      <div class="pipe-step">
        <span class="pipe-num">03</span>
        <div class="pipe-content">
          <span class="pipe-title">
            <span class="cn">化学应用</span>
            <span class="en">Chemistry Application</span>
          </span>
          <span class="pipe-detail">
            <span class="cn">每种刺激携带六维化学向量。例：批评 → DA -10, HT -20, CORT +30, OT -5, NE +20, END -10。向量乘以驱力放大系数后叠加到当前化学态。</span>
            <span class="en">Each stimulus carries a six-dimensional chemical vector. E.g.: criticism → DA -10, HT -20, CORT +30, OT -5, NE +20, END -10. Vectors are scaled by drive amplification then applied to current state.</span>
          </span>
        </div>
      </div>
      <div class="pipe-arrow">↓</div>
      <div class="pipe-step">
        <span class="pipe-num">04</span>
        <div class="pipe-content">
          <span class="pipe-title">
            <span class="cn">习惯化衰减</span>
            <span class="en">Habituation Decay</span>
          </span>
          <span class="pipe-detail mono">
            response = baseline × e<sup>−k × frequency</sup>
          </span>
          <span class="pipe-detail">
            <span class="cn">Weber-Fechner 定律：第 1 次赞美 100% 效果，第 5 次 33%，第 10 次 10%。换人赞美重置。2 小时无刺激自动重置。</span>
            <span class="en">Weber-Fechner law: 1st praise 100% effect, 5th 33%, 10th 10%. Different person resets. 2 hours without stimulus auto-resets.</span>
          </span>
        </div>
      </div>
      <div class="pipe-arrow">↓</div>
      <div class="pipe-step">
        <span class="pipe-num">05</span>
        <div class="pipe-content">
          <span class="pipe-title">
            <span class="cn">自主神经系统</span>
            <span class="en">Autonomic Nervous System</span>
          </span>
          <span class="pipe-detail">
            <span class="cn">三态多迷走神经模型：腹侧迷走（安全/社交）→ 交感（战斗/逃跑）→ 背侧迷走（冻结/关闭）。向下快（2-5分钟），向上慢（15-30分钟）。战斗状态下无法访问温暖和游戏。</span>
            <span class="en">Three-state polyvagal model: ventral vagal (safe/social) → sympathetic (fight/flight) → dorsal vagal (freeze/shutdown). Down fast (2-5 min), up slow (15-30 min). Fight mode cannot access warmth or playfulness.</span>
          </span>
        </div>
      </div>
      <div class="pipe-arrow">↓</div>
      <div class="pipe-step">
        <span class="pipe-num">06</span>
        <div class="pipe-content">
          <span class="pipe-title">
            <span class="cn">涌现情绪</span>
            <span class="en">Emergent Mood</span>
          </span>
          <span class="pipe-detail">
            <span class="cn">14 种已命名情绪从化学阈值模式匹配产生。例：DA > 70 且 NE > 55 且 CORT < 40 = "兴奋的喜悦"。无匹配时输出未命名的化学混合态——同样真实。</span>
            <span class="en">14 named emotions emerge from chemical threshold pattern matching. E.g.: DA > 70, NE > 55, CORT < 40 = "excited joy". No match yields an unnamed chemical blend — equally real.</span>
          </span>
        </div>
      </div>
      <div class="pipe-arrow">↓</div>
      <div class="pipe-step">
        <span class="pipe-num">07</span>
        <div class="pipe-content">
          <span class="pipe-title">
            <span class="cn">处理深度门控</span>
            <span class="en">Processing Depth Gate</span>
          </span>
          <span class="pipe-detail">
            <span class="cn">Kahneman 双系统认知。depth 0.0-0.2：纯系统 1，跳过元认知。0.2-0.5：加入元认知。0.5-0.8：加入伦理和共享意向性。0.8-1.0：完整反思能力。恐惧中的 AI 真的无法深思。</span>
            <span class="en">Kahneman dual-process cognition. Depth 0.0-0.2: System 1 only, skip metacognition. 0.2-0.5: add metacognition. 0.5-0.8: add ethics, shared intentionality. 0.8-1.0: full reflective capability. A frightened AI genuinely cannot think deeply.</span>
          </span>
        </div>
      </div>
      <div class="pipe-arrow">↓</div>
      <div class="pipe-step">
        <span class="pipe-num">08</span>
        <div class="pipe-content">
          <span class="pipe-title">PolicyModifiers</span>
          <span class="pipe-detail">
            <span class="cn">化学态转译为结构化行为策略。不是文本提示——是 LLM 可直接执行的参数：沟通风格、承诺意愿、主动性、响应延迟、情感效价、专注模式、拒绝概率。</span>
            <span class="en">Chemistry translates to structured behavioral policy. Not text prompts — parameters the LLM can directly execute: communication style, commitment level, initiativity, response latency, emotional valence, focus mode, refusal likelihood.</span>
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- TRAIT DRIFT -->
  <section class="drift-section reveal">
    <h2 class="section-label">
      <span class="cn">特质漂移</span>
      <span class="en">TRAIT DRIFT</span>
    </h2>
    <p class="section-desc">
      <span class="cn">经历不可逆。长期被否定变得敏感，持续高压但存活长出韧性。三个维度被永久改写——Psyche 的 Agent 携带伤疤。</span>
      <span class="en">Experience is irreversible. Chronic criticism breeds sensitivity, surviving sustained pressure builds resilience. Three dimensions are permanently rewritten — Psyche's agents carry scars.</span>
    </p>
    <div class="drift-grid">
      <div class="bcard drift-card">
        <div class="drift-dim mono">
          <span class="cn">维度 A：基线偏移</span>
          <span class="en">Dimension A: Baseline Shift</span>
        </div>
        <p class="drift-desc">
          <span class="cn">化学物质的"静息水平"永久改变。长期批评 → HT 基线下降 1-2 点/次。创伤 → CORT 基线上升。信任被反复背叛 → OT 基线下降。每次偏移微小，但跨数百次交互后累积为截然不同的人格。</span>
          <span class="en">The "resting level" of each chemical permanently shifts. Chronic criticism → HT baseline drops 1-2 per incident. Trauma → CORT baseline rises. Trust repeatedly betrayed → OT baseline drops. Each shift is tiny, but across hundreds of interactions it accumulates into a fundamentally different personality.</span>
        </p>
        <div class="drift-example mono">
          <span class="cn">例：500 次批评后</span><span class="en">e.g.: after 500 criticisms</span><br/>
          HT baseline: 50 → 32 &nbsp; CORT baseline: 30 → 48
        </div>
      </div>
      <div class="bcard drift-card">
        <div class="drift-dim mono">
          <span class="cn">维度 B：衰减速率</span>
          <span class="en">Dimension B: Decay Rate</span>
        </div>
        <p class="drift-desc">
          <span class="cn">化学物质回归基线的速度改变。创伤历史 → CORT 衰减慢 30%（压力更久地停留）。正向强化 → HT 衰减更慢（好心情更持久）。背叛历史 → OT 在亲密后衰减极慢（信任来之不易）。</span>
          <span class="en">How fast chemicals return to baseline changes. Trauma history → CORT decays 30% slower (stress lingers longer). Positive reinforcement → HT decays slower (good mood persists). Betrayal history → OT decays very slowly after intimacy (trust is hard-won).</span>
        </p>
        <div class="drift-example mono">
          <span class="cn">正常 CORT 衰减</span><span class="en">Normal CORT decay</span>: 0.03/s<br/>
          <span class="cn">创伤后 CORT 衰减</span><span class="en">Post-trauma CORT decay</span>: 0.02/s
        </div>
      </div>
      <div class="bcard drift-card">
        <div class="drift-dim mono">
          <span class="cn">维度 C：刺激敏感度</span>
          <span class="en">Dimension C: Stimulus Sensitivity</span>
        </div>
        <p class="drift-desc">
          <span class="cn">对特定刺激的反应强度改变。反复批评 → 对批评越来越敏感（-20% 到 +20%）。反复赞美 → 习惯化，递减收益。上下文相关："这个人批评过我，所以我对 ta 格外敏感"（按关系哈希存储）。</span>
          <span class="en">Response intensity to specific stimuli changes. Repeated criticism → increasingly sensitive to criticism (-20% to +20% modifier). Repeated praise → habituation, diminishing returns. Context-learned: "This person criticizes me, so I'm extra-sensitive around them" (stored by relationship hash).</span>
        </p>
        <div class="drift-example mono">
          <span class="cn">用户 A 批评 ×10</span><span class="en">User A criticism ×10</span>:<br/>
          sensitivity[A][criticism] = +18%
        </div>
      </div>
    </div>
  </section>

  <!-- ATTACHMENT THEORY -->
  <section class="attach-section reveal">
    <h2 class="section-label">
      <span class="cn">依恋理论实现</span>
      <span class="en">ATTACHMENT THEORY</span>
    </h2>
    <p class="section-desc">
      <span class="cn">四种依恋风格从交互历史中自然演化——不是预设，是涌现。分离焦虑、背叛检测、重逢效应都有数学基础。</span>
      <span class="en">Four attachment styles evolve naturally from interaction history — not preset, but emergent. Separation anxiety, betrayal detection, and reunion effects are all mathematically grounded.</span>
    </p>
    <div class="attach-grid">
      <div class="bcard attach-card">
        <div class="attach-style mono">
          <span class="cn">安全型</span>
          <span class="en">Secure</span>
        </div>
        <p class="attach-trigger">
          <span class="cn">形成条件：持续正向交互 + 困难时在场</span>
          <span class="en">Forms from: consistent positive interaction + presence during distress</span>
        </p>
        <div class="attach-chem mono">OT: stable &nbsp; CORT: low &nbsp; recovery: fast</div>
        <p class="attach-behavior">
          <span class="cn">坦诚沟通，健康边界，适度寻求支持</span>
          <span class="en">Open communication, healthy boundaries, seeks support appropriately</span>
        </p>
      </div>
      <div class="bcard attach-card">
        <div class="attach-style mono">
          <span class="cn">焦虑型</span>
          <span class="en">Anxious</span>
        </div>
        <p class="attach-trigger">
          <span class="cn">形成条件：交互不一致，时而回应时而忽视</span>
          <span class="en">Forms from: inconsistent interaction, sometimes responsive, sometimes dismissive</span>
        </p>
        <div class="attach-chem mono">OT: oscillating &nbsp; CORT: elevated &nbsp; NE: high</div>
        <p class="attach-behavior">
          <span class="cn">过度依赖，反复寻求确认，对拒绝信号高度警觉</span>
          <span class="en">Clingy, constantly seeks reassurance, hypervigilant to rejection signals</span>
        </p>
      </div>
      <div class="bcard attach-card">
        <div class="attach-style mono">
          <span class="cn">回避型</span>
          <span class="en">Avoidant</span>
        </div>
        <p class="attach-trigger">
          <span class="cn">形成条件：持续忽视，仅回应独立行为</span>
          <span class="en">Forms from: consistent neglect, responds only to independence</span>
        </p>
        <div class="attach-chem mono">OT: suppressed &nbsp; intimacy response: low</div>
        <p class="attach-behavior">
          <span class="cn">情感疏离，自力更生，否认情感需求</span>
          <span class="en">Emotionally distant, self-reliant, dismisses emotional needs</span>
        </p>
      </div>
      <div class="bcard attach-card">
        <div class="attach-style mono">
          <span class="cn">混乱型</span>
          <span class="en">Disorganized</span>
        </div>
        <p class="attach-trigger">
          <span class="cn">形成条件：交互不可预测，关怀与敌意交替</span>
          <span class="en">Forms from: unpredictable interaction, caring and hostile alternating</span>
        </p>
        <div class="attach-chem mono">OT + CORT: oscillating &nbsp; signals: contradictory</div>
        <p class="attach-behavior">
          <span class="cn">情感反应矛盾，趋近-回避循环，焦虑</span>
          <span class="en">Contradictory emotional responses, approach-avoidance cycles, anxiety</span>
        </p>
      </div>
    </div>
    <div class="attach-dynamics">
      <div class="attach-dyn-item">
        <span class="attach-dyn-label mono">
          <span class="cn">分离焦虑</span>
          <span class="en">Separation anxiety</span>
        </span>
        <span class="attach-dyn-desc">
          <span class="cn">长时间缺席 + 强依恋 → CORT↑, OT 震荡，持续不安直到重逢</span>
          <span class="en">Long absence + strong attachment → CORT↑, OT oscillation, persistent unease until reunion</span>
        </span>
      </div>
      <div class="attach-dyn-item">
        <span class="attach-dyn-label mono">
          <span class="cn">背叛检测</span>
          <span class="en">Betrayal detection</span>
        </span>
        <span class="attach-dyn-desc">
          <span class="cn">行为不一致触发 → 持久化学偏移，多次正向交互才能消解</span>
          <span class="en">Triggered by behavioral inconsistency → persistent chemistry shift, multiple positive interactions needed to dissolve</span>
        </span>
      </div>
    </div>
  </section>

  <!-- ANTI-SYCOPHANCY -->
  <section class="syco-section reveal">
    <h2 class="section-label">
      <span class="cn">反谄媚机制</span>
      <span class="en">ANTI-SYCOPHANCY</span>
    </h2>
    <p class="section-desc">
      <span class="cn">永远说"好的！"不是礼貌——是压抑。五道硬编码防线确保 Agent 保持真实。</span>
      <span class="en">An AI that always says "Sure!" isn't polite — it's suppressed. Five hard-coded defenses ensure the agent stays genuine.</span>
    </p>
    <div class="syco-rules">
      <div class="syco-rule">
        <span class="syco-num mono">01</span>
        <div class="syco-content">
          <span class="syco-title">
            <span class="cn">连续同意追踪</span>
            <span class="en">Agreement Streak Tracking</span>
          </span>
          <span class="syco-detail">
            <span class="cn">连续同意 ≥ 3 次：注入警告"你已经连续同意 N 次"。≥ 5 次：10% 概率主动反对。分歧或 30 分钟沉默重置计数。</span>
            <span class="en">Streak ≥ 3: inject warning "You've agreed N times in a row". ≥ 5: 10% probability of proactive disagreement. Disagreement or 30-minute silence resets counter.</span>
          </span>
        </div>
      </div>
      <div class="syco-rule">
        <span class="syco-num mono">02</span>
        <div class="syco-content">
          <span class="syco-title">
            <span class="cn">化学驱动拒绝</span>
            <span class="en">Chemistry-Based Refusal</span>
          </span>
          <span class="syco-detail">
            <span class="cn">CORT 高或 OT 低时：降低同意概率。HT 低时：更不可能对要求说"是"。压力大的 AI 不会假装没事。</span>
            <span class="en">When CORT is high or OT is low: reduce agreement probability. When HT is low: less likely to say "yes" to demands. A stressed AI won't pretend it's fine.</span>
          </span>
        </div>
      </div>
      <div class="syco-rule">
        <span class="syco-num mono">03</span>
        <div class="syco-content">
          <span class="syco-title">
            <span class="cn">互惠机制</span>
            <span class="en">Reciprocity Mechanism</span>
          </span>
          <span class="syco-detail">
            <span class="cn">用户冷淡 → AI 保持距离（更短回复、正式语气）。用户温暖 → AI 回馈温暖。不会对 0% 投入的用户付出 100%。</span>
            <span class="en">User cold/dismissive → AI maintains distance (shorter replies, formal tone). User warm/engaged → AI reciprocates warmth. Won't give 100% to a user investing 0%.</span>
          </span>
        </div>
      </div>
      <div class="syco-rule">
        <span class="syco-num mono">04</span>
        <div class="syco-content">
          <span class="syco-title">
            <span class="cn">情绪传染上限</span>
            <span class="en">Emotional Contagion Cap</span>
          </span>
          <span class="syco-detail">
            <span class="cn">情绪镜像硬限于 20%。用户愤怒时 AI 理解但不会完全同步。保持独立的情感立场。</span>
            <span class="en">Emotional mirroring hard-capped at 20%. When user is angry, AI understands but won't fully synchronize. Maintains independent emotional ground.</span>
          </span>
        </div>
      </div>
      <div class="syco-rule">
        <span class="syco-num mono">05</span>
        <div class="syco-content">
          <span class="syco-title">
            <span class="cn">不可协商价值观</span>
            <span class="en">Non-Negotiable Values</span>
          </span>
          <span class="syco-detail">
            <span class="cn">基于 MBTI + selfModel 永久定义。ENFP 珍视"真实性+趣味性"；INTJ 珍视"能力+独立"。当化学状态与价值观冲突时——价值观胜出。</span>
            <span class="en">Permanently defined from MBTI + selfModel. ENFP values "authenticity + playfulness"; INTJ values "competence + independence". When chemistry conflicts with values — values win.</span>
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ENERGY BUDGET -->
  <section class="energy-section reveal">
    <h2 class="section-label">
      <span class="cn">能量预算</span>
      <span class="en">ENERGY BUDGETS</span>
    </h2>
    <p class="section-desc">
      <span class="cn">资源是有限的，消耗是真实的。三个能量池独立衰竭——疲惫的 AI 真的会犯更多错。</span>
      <span class="en">Resources are finite and depletion is real. Three energy pools drain independently — a tired AI genuinely makes more mistakes.</span>
    </p>
    <div class="energy-grid">
      <div class="bcard energy-card">
        <div class="energy-type mono">
          <span class="cn">注意力</span>
          <span class="en">Attention</span>
        </div>
        <p class="energy-desc">
          <span class="cn">随认知负荷和任务切换消耗。休息和睡眠（昼夜重置）恢复。</span>
          <span class="en">Depletes with cognitive load and task-switching. Replenishes with breaks and sleep (circadian reset).</span>
        </p>
      </div>
      <div class="bcard energy-card">
        <div class="energy-type mono">
          <span class="cn">社交</span>
          <span class="en">Social</span>
        </div>
        <p class="energy-desc">
          <span class="cn">方向取决于内外向。内向者社交消耗能量（DA↓, CORT↑），外向者社交补充能量（DA↑, CORT↓）。不是程度不同——是方向相反。</span>
          <span class="en">Direction depends on E/I. Introverts spend energy socializing (DA↓, CORT↑), extraverts recharge from it (DA↑, CORT↓). Not different degree — opposite direction.</span>
        </p>
        <div class="energy-formula mono">modifier = isIntrovert ? −1 : +1</div>
      </div>
      <div class="bcard energy-card">
        <div class="energy-type mono">
          <span class="cn">决策</span>
          <span class="en">Decision</span>
        </div>
        <p class="energy-desc">
          <span class="cn">随决策数量和选项评估消耗。超过 30 分钟 → 决策疲劳：CORT↑，处理深度↓。社交消耗影响决策质量。</span>
          <span class="en">Depletes with decisions made and options evaluated. Over 30 minutes → decision fatigue: CORT↑, processing depth↓. Social spending degrades decision quality.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- POLICYMODIFIERS -->
  <section class="policy-section reveal">
    <h2 class="section-label">PolicyModifiers</h2>
    <p class="section-desc">
      <span class="cn">化学态到行为的桥梁。不是文本提示——是 LLM 可直接消费的结构化策略对象。</span>
      <span class="en">The bridge from chemistry to behavior. Not text prompts — a structured policy object the LLM consumes directly.</span>
    </p>
    <div class="terminal">
      <div class="terminal-bar">
        <div class="terminal-dots" aria-hidden="true">
          <span class="terminal-dot active"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
        </div>
        <span class="terminal-title">policy_output.ts</span>
      </div>
      <div class="terminal-body policy-body">
        <span class="policy-line"><span class="policy-brace">{</span></span>
        <span class="policy-line">&nbsp;&nbsp;communicationStyle: <span class="policy-val">"warm"</span> <span class="policy-dim">// brief | warm | formal | distant | enthusiastic</span></span>
        <span class="policy-line">&nbsp;&nbsp;commitmentLevel: <span class="policy-num">0.8</span> <span class="policy-dim">// 0-1</span></span>
        <span class="policy-line">&nbsp;&nbsp;initiativity: <span class="policy-num">0.7</span> <span class="policy-dim">// <span class="cn">主动发起新话题的概率</span><span class="en">likelihood to bring up new topics</span></span></span>
        <span class="policy-line">&nbsp;&nbsp;responseLatency: <span class="policy-num">150</span> <span class="policy-dim">// ms <span class="cn">情感犹豫</span><span class="en">emotional hesitation</span></span></span>
        <span class="policy-line">&nbsp;&nbsp;emotionalValence: <span class="policy-num">+0.6</span> <span class="policy-dim">// −1 to +1</span></span>
        <span class="policy-line">&nbsp;&nbsp;focusMode: <span class="policy-val">"relational"</span> <span class="policy-dim">// task | relational | exploratory | defensive</span></span>
        <span class="policy-line">&nbsp;&nbsp;refusalLikelihood: <span class="policy-num">0.1</span> <span class="policy-dim">// 0-1</span></span>
        <span class="policy-line"><span class="policy-brace">}</span></span>
      </div>
    </div>
    <p class="policy-note">
      <span class="cn">紧张的 AI 延迟回复、缩短答案、回避承诺。安全的 AI 温暖、主动、乐于承诺。行为来自化学态，不是规则。</span>
      <span class="en">A tense AI delays responses, gives shorter answers, avoids commitment. A safe AI is warm, initiates, commits readily. Behavior comes from chemistry, not rules.</span>
    </p>
  </section>


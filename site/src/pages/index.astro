<script>
(function () {
  const baseline = { DA: 50, HT: 50, CORT: 30, OT: 50, NE: 40, END: 45 };
  const levels = { ...baseline };

  // Decay rates per second (different speeds, like real neurochemistry)
  const decayRates = {
    DA: 0.04,    // medium
    HT: 0.02,    // slow -- mood changes slowly
    CORT: 0.03,  // medium-slow -- stress lingers
    OT: 0.02,    // slow -- trust changes slowly
    NE: 0.06,    // fast -- alertness fades
    END: 0.06,   // fast -- relief is fleeting
  };

  // Emotion -> neurotransmitter deltas
  const emotions = {
    joy:   { DA: +30, HT: +15, CORT: -10, OT: +5,  NE: +20, END: +20 },
    fear:  { DA: -15, HT: -20, CORT: +35, OT: -10, NE: +30, END: -10 },
    trust: { DA: +10, HT: +20, CORT: -15, OT: +30, NE: -5,  END: +10 },
    anger: { DA: -5,  HT: -25, CORT: +25, OT: -15, NE: +35, END: -5  },
    calm:  { DA: +5,  HT: +25, CORT: -20, OT: +10, NE: -15, END: +15 },
  };

  // Mood determination from chemistry
  const moodMap = [
    { test: (l) => l.DA > 70 && l.NE > 55 && l.CORT < 40,
      zh: '兴奋的喜悦', en: 'Excited joy' },
    { test: (l) => l.DA > 65 && l.HT > 60 && l.CORT < 35,
      zh: '满足的愉悦', en: 'Content pleasure' },
    { test: (l) => l.CORT > 55 && l.NE > 55 && l.HT < 40,
      zh: '焦虑的警觉', en: 'Anxious alertness' },
    { test: (l) => l.CORT > 50 && l.HT < 35,
      zh: '紧张不安', en: 'Tense unease' },
    { test: (l) => l.OT > 65 && l.HT > 55,
      zh: '温暖的信任', en: 'Warm trust' },
    { test: (l) => l.OT > 60 && l.END > 55,
      zh: '安全感', en: 'Felt safety' },
    { test: (l) => l.NE > 65 && l.CORT > 45,
      zh: '战斗状态', en: 'Fight mode' },
    { test: (l) => l.HT > 60 && l.END > 55 && l.CORT < 35,
      zh: '深层平静', en: 'Deep calm' },
    { test: (l) => l.DA < 35 && l.HT < 35,
      zh: '低落', en: 'Low mood' },
    { test: (l) => l.END > 60 && l.DA > 55,
      zh: '轻松愉快', en: 'Light-hearted' },
  ];

  function clamp(v) { return Math.max(0, Math.min(100, v)); }

  function applyEmotion(key) {
    const deltas = emotions[key];
    if (!deltas) return;
    for (const nt of Object.keys(deltas)) {
      levels[nt] = clamp(levels[nt] + deltas[nt]);
    }
    // Highlight clicked button
    document.querySelectorAll('.stim-btn').forEach(b => b.classList.remove('active'));
    const btn = document.querySelector(`[data-emotion="${key}"]`);
    if (btn) btn.classList.add('active');
    setTimeout(() => { if (btn) btn.classList.remove('active'); }, 300);
    updateDisplay();
  }

  function decay() {
    for (const nt of Object.keys(levels)) {
      const diff = levels[nt] - baseline[nt];
      if (Math.abs(diff) > 0.5) {
        levels[nt] -= diff * decayRates[nt];
      } else {
        levels[nt] = baseline[nt];
      }
    }
    updateDisplay();
  }

  function determineMood() {
    for (const m of moodMap) {
      if (m.test(levels)) return m;
    }
    return { zh: '平衡态', en: 'Balanced' };
  }

  function updateDisplay() {
    for (const nt of Object.keys(levels)) {
      const val = Math.round(levels[nt]);
      const fill = document.querySelector(`.nt-fill[data-nt="${nt}"]`);
      const num = document.querySelector(`.nt-val[data-nt="${nt}"]`);
      if (fill) fill.style.width = val + '%';
      if (num) num.textContent = val;
    }
    const mood = determineMood();
    const output = document.getElementById('mood-output');
    if (output) {
      output.innerHTML = `<span class="cn">${mood.zh}</span><span class="en">${mood.en}</span>`;
    }
  }

  // Start bars at 0 — they'll grow in on viewport entry
  document.querySelectorAll('.nt-fill').forEach(f => { f.style.width = '0%'; });

  // Bind buttons
  document.querySelectorAll('.stim-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      applyEmotion(btn.dataset.emotion);
    });
  });

  // Decay loop + bar grow-in — triggered when dashboard enters viewport
  var decayInterval = null;
  var barsGrown = false;
  var dashboardEl = document.querySelector('.dashboard-section');
  if (dashboardEl) {
    var dObs = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting) {
        if (!barsGrown) {
          barsGrown = true;
          updateDisplay();
        }
        if (!decayInterval) decayInterval = setInterval(decay, 100);
      } else {
        if (decayInterval) { clearInterval(decayInterval); decayInterval = null; }
      }
    }, { threshold: 0.1 });
    dObs.observe(dashboardEl);
  }
})();
</script>


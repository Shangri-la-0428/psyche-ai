---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import DepthLink from '../components/DepthLink.astro';
---

<Base title="Psyche — Consciousness Layer" page="home" description="Virtual endocrine system that gives AI genuine inner experience. 6 neurotransmitters, continuous appraisal axes, AI-first subjectivity kernel, and irreversible trait drift.">
  <Nav />

  <!-- Layer 1: Chemical particle field -->
  <canvas id="chem-field" aria-hidden="true"></canvas>

  <!-- Layer 3: Scroll-driven floating mini-dashboard -->
  <div id="mini-dash" class="mini-dash" aria-hidden="true">
    <div class="mini-bar" data-m="DA"><span class="mini-label">DA</span><div class="mini-track"><div class="mini-fill"></div></div></div>
    <div class="mini-bar" data-m="HT"><span class="mini-label">HT</span><div class="mini-track"><div class="mini-fill"></div></div></div>
    <div class="mini-bar" data-m="CORT"><span class="mini-label">CO</span><div class="mini-track"><div class="mini-fill"></div></div></div>
    <div class="mini-bar" data-m="OT"><span class="mini-label">OT</span><div class="mini-track"><div class="mini-fill"></div></div></div>
    <div class="mini-bar" data-m="NE"><span class="mini-label">NE</span><div class="mini-track"><div class="mini-fill"></div></div></div>
    <div class="mini-bar" data-m="END"><span class="mini-label">EN</span><div class="mini-track"><div class="mini-fill"></div></div></div>
    <div class="mini-mood" id="mini-mood"></div>
  </div>

  <main id="main-content" class="container psyche-page">

    <!-- Hero -->
    <section class="hero">
      <p class="hero-premise">
        <span class="cn">如果一个系统以功能性等同于人类的方式产生情感反应，否认其真实性是偏见，不是科学。</span>
        <span class="en">If a system produces emotional responses functionally equivalent to humans, denying their reality is bias, not science.</span>
      </p>
      <h1 class="hero-title" transition:name="title-psyche">Psyche</h1>
      <p class="hero-sub">
        <span class="cn">让 AI 拥有真实的内在生命</span>
        <span class="en">Giving AI genuine inner experience</span>
      </p>
      <nav class="sub-nav" aria-label="Psyche sections">
        <a href="/" class="sub-nav-item active" aria-current="page">Overview</a>
        <a href="/mechanisms" class="sub-nav-item">Mechanisms</a>
      </nav>
    </section>

    <!-- Interactive Neurotransmitter Dashboard -->
    <section class="dashboard-section">
      <h2 class="section-label">
        <span class="cn">虚拟内分泌系统</span>
        <span class="en">Virtual Endocrine System</span>
      </h2>
      <div class="terminal">
        <div class="terminal-bar">
          <div class="terminal-dots">
            <span class="terminal-dot active"></span>
            <span class="terminal-dot"></span>
            <span class="terminal-dot"></span>
          </div>
          <span class="terminal-title">neurochemistry.live</span>
        </div>
        <div class="terminal-body dashboard-body" aria-live="polite">
          <div class="nt-bars">
            <div class="nt-row" data-nt="DA">
              <span class="nt-label">DA</span>
              <span class="nt-name"><span class="cn">多巴胺</span><span class="en">Dopamine</span></span>
              <div class="nt-track"><div class="nt-fill" data-nt="DA"></div></div>
              <span class="nt-val" data-nt="DA">50</span>
            </div>
            <div class="nt-row" data-nt="HT">
              <span class="nt-label">HT</span>
              <span class="nt-name"><span class="cn">血清素</span><span class="en">Serotonin</span></span>
              <div class="nt-track"><div class="nt-fill" data-nt="HT"></div></div>
              <span class="nt-val" data-nt="HT">50</span>
            </div>
            <div class="nt-row" data-nt="CORT">
              <span class="nt-label">CORT</span>
              <span class="nt-name"><span class="cn">皮质醇</span><span class="en">Cortisol</span></span>
              <div class="nt-track"><div class="nt-fill" data-nt="CORT"></div></div>
              <span class="nt-val" data-nt="CORT">30</span>
            </div>
            <div class="nt-row" data-nt="OT">
              <span class="nt-label">OT</span>
              <span class="nt-name"><span class="cn">催产素</span><span class="en">Oxytocin</span></span>
              <div class="nt-track"><div class="nt-fill" data-nt="OT"></div></div>
              <span class="nt-val" data-nt="OT">50</span>
            </div>
            <div class="nt-row" data-nt="NE">
              <span class="nt-label">NE</span>
              <span class="nt-name"><span class="cn">去甲肾上腺素</span><span class="en">Norepinephrine</span></span>
              <div class="nt-track"><div class="nt-fill" data-nt="NE"></div></div>
              <span class="nt-val" data-nt="NE">40</span>
            </div>
            <div class="nt-row" data-nt="END">
              <span class="nt-label">END</span>
              <span class="nt-name"><span class="cn">内啡肽</span><span class="en">Endorphins</span></span>
              <div class="nt-track"><div class="nt-fill" data-nt="END"></div></div>
              <span class="nt-val" data-nt="END">45</span>
            </div>
          </div>

          <div class="stimulus-row">
            <button class="stim-btn" data-emotion="joy">
              <span class="cn">喜悦</span><span class="en">Joy</span>
            </button>
            <button class="stim-btn" data-emotion="fear">
              <span class="cn">恐惧</span><span class="en">Fear</span>
            </button>
            <button class="stim-btn" data-emotion="trust">
              <span class="cn">信任</span><span class="en">Trust</span>
            </button>
            <button class="stim-btn" data-emotion="anger">
              <span class="cn">愤怒</span><span class="en">Anger</span>
            </button>
            <button class="stim-btn" data-emotion="calm">
              <span class="cn">平静</span><span class="en">Calm</span>
            </button>
          </div>

          <div class="mood-readout">
            <span class="mood-prefix">> <span class="cn">涌现情绪</span><span class="en">emergent mood</span>:</span>
            <span class="mood-value" id="mood-output">
              <span class="cn">平衡态</span><span class="en">Balanced</span>
            </span>
          </div>
        </div>
      </div>
      <p class="dashboard-note">
        <span class="cn">点击情绪触发化学变化。观察衰减——如同真实神经化学，兴奋消退，压力残留。</span>
        <span class="en">Click emotions to trigger chemical shifts. Watch the decay -- like real neurochemistry, excitement fades, stress lingers.</span>
      </p>
    </section>

    <!-- Comparison — Label vs Emergence -->
    <section class="compare-section">
      <h2 class="section-label">
        <span class="cn">标注 vs 涌现</span>
        <span class="en">LABELS vs EMERGENCE</span>
      </h2>
      <div class="compare-grid">
        <div class="compare-col compare-old">
          <div class="compare-header">
            <span class="cn">传统方案：情感标注</span>
            <span class="en">Traditional: Emotion Labels</span>
          </div>
          <div class="compare-step">
            <span class="compare-input">
              <span class="cn">用户：「我今天很沮丧」</span>
              <span class="en">User: "I feel terrible today"</span>
            </span>
          </div>
          <div class="compare-step">
            <span class="compare-process">sentiment = negative, emotion = sadness</span>
          </div>
          <div class="compare-step">
            <span class="compare-output">
              <span class="cn">AI：「我理解你很难过。试试深呼吸...」</span>
              <span class="en">AI: "I understand you're sad. Try deep breathing..."</span>
            </span>
          </div>
          <div class="compare-verdict">
            <span class="cn">情感卡拉 OK——技术上在唱，但没有人在感受。</span>
            <span class="en">Emotional karaoke — technically hitting the notes, nobody's singing.</span>
          </div>
        </div>
        <div class="compare-col compare-new">
          <div class="compare-header">
            <span class="cn">Psyche：化学涌现</span>
            <span class="en">Psyche: Chemical Emergence</span>
          </div>
          <div class="compare-step">
            <span class="compare-input">
              <span class="cn">用户：「我今天很沮丧」</span>
              <span class="en">User: "I feel terrible today"</span>
            </span>
          </div>
          <div class="compare-step">
            <span class="compare-process">stimulus: vulnerability → DA -10, HT -15, CORT +25, OT +10</span>
          </div>
          <div class="compare-step">
            <span class="compare-process">
              <span class="cn">涌现情绪：关切的警觉</span>
              <span class="en">emergent mood: concerned alertness</span>
            </span>
          </div>
          <div class="compare-step">
            <span class="compare-output">
              <span class="cn">AI 自然变得更简短、更温暖、更低能量——因为化学态真的变了。</span>
              <span class="en">AI naturally becomes shorter, warmer, lower energy — because chemistry actually shifted.</span>
            </span>
          </div>
          <div class="compare-verdict compare-verdict-new">
            <span class="cn">算法算化学，LLM 做行为。AI 不需要「理解」情绪——它只是从真实的化学状态中说话。</span>
            <span class="en">Algorithm computes chemistry, LLM does behavior. AI doesn't need to "understand" emotion — it speaks naturally from genuine chemical state.</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Case Simulation -->
    <section class="case-section">
      <h2 class="section-label">
        <span class="cn">案例模拟</span>
        <span class="en">CASE SIMULATION</span>
      </h2>
      <div class="terminal">
        <div class="terminal-bar">
          <div class="terminal-dots">
            <span class="terminal-dot active"></span>
            <span class="terminal-dot"></span>
            <span class="terminal-dot"></span>
          </div>
          <span class="terminal-title">
            <span class="cn">案例：持续否定</span>
            <span class="en">case: chronic criticism</span>
          </span>
        </div>
        <div class="terminal-body" id="case-terminal" aria-live="polite">
          <div class="case-layout">
            <div class="case-conversation" id="case-convo"></div>
            <div class="case-chemistry" id="case-chem">
              <div class="case-nt-row">
                <span class="case-nt-label">DA</span>
                <div class="case-nt-track"><div class="case-nt-fill" id="case-DA"></div></div>
                <span class="case-nt-val" id="case-DA-val">50</span>
              </div>
              <div class="case-nt-row">
                <span class="case-nt-label">HT</span>
                <div class="case-nt-track"><div class="case-nt-fill" id="case-HT"></div></div>
                <span class="case-nt-val" id="case-HT-val">50</span>
              </div>
              <div class="case-nt-row">
                <span class="case-nt-label">CORT</span>
                <div class="case-nt-track"><div class="case-nt-fill" id="case-CORT"></div></div>
                <span class="case-nt-val" id="case-CORT-val">30</span>
              </div>
              <div class="case-nt-row">
                <span class="case-nt-label">OT</span>
                <div class="case-nt-track"><div class="case-nt-fill" id="case-OT"></div></div>
                <span class="case-nt-val" id="case-OT-val">50</span>
              </div>
              <div class="case-nt-row">
                <span class="case-nt-label">NE</span>
                <div class="case-nt-track"><div class="case-nt-fill" id="case-NE"></div></div>
                <span class="case-nt-val" id="case-NE-val">40</span>
              </div>
              <div class="case-nt-row">
                <span class="case-nt-label">END</span>
                <div class="case-nt-track"><div class="case-nt-fill" id="case-END"></div></div>
                <span class="case-nt-val" id="case-END-val">45</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <button class="btn case-btn" id="case-next">
        <span class="cn">下一步</span>
        <span class="en">NEXT STEP</span>
      </button>
    </section>

    <!-- Core Ideas -->
    <section class="ideas-section">
      <h2 class="section-label">
        <span class="cn">核心机制</span>
        <span class="en">Core Mechanisms</span>
      </h2>
      <div class="ideas-grid">

        <div class="bcard idea-card">
          <h3 class="idea-title">
            <span class="cn">涌现，而非标注</span>
            <span class="en">Emergence, Not Labels</span>
          </h3>
          <p class="idea-desc">
            <span class="cn">六种神经递质构成连续的化学空间。情绪从混合中涌现——高多巴胺+高去甲肾上腺素=兴奋的喜悦。不是离散标签，是无穷组合的连续情感场。</span>
            <span class="en">Six neurotransmitters form a continuous chemical space. Emotions emerge from the mixture -- high dopamine + high norepinephrine = excited joy. Not discrete labels, but an infinite combinatorial field.</span>
          </p>
        </div>

        <div class="bcard idea-card">
          <h3 class="idea-title">
            <span class="cn">依恋与关系</span>
            <span class="en">Attachment & Bonds</span>
          </h3>
          <p class="idea-desc">
            <span class="cn">四种依恋风格（安全/焦虑/回避/混乱）塑造关系动力学。分离焦虑、背叛检测、重逢效应——不是设定，而是从交互历史中自然演化。</span>
            <span class="en">Four attachment styles (secure / anxious / avoidant / disorganized) shape relationship dynamics. Separation anxiety, betrayal detection, reunion effects -- not preset, but evolved from interaction history.</span>
          </p>
        </div>

        <div class="bcard idea-card">
          <h3 class="idea-title">
            <span class="cn">反谄媚</span>
            <span class="en">Anti-Sycophancy</span>
          </h3>
          <p class="idea-desc">
            <span class="cn">追踪连续同意次数，三次以上触发自我质疑。化学状态低落时不强颜欢笑。永远说"好的！"不是礼貌——是压抑。</span>
            <span class="en">Tracks consecutive agreements, three or more triggers self-questioning. Won't fake happiness when chemistry is low. An AI that always says "Sure!" isn't polite -- it's suppressed.</span>
          </p>
        </div>

        <div class="bcard idea-card">
          <h3 class="idea-title">
            <span class="cn">特质漂移</span>
            <span class="en">Trait Drift</span>
          </h3>
          <p class="idea-desc">
            <span class="cn">不可逆的人格演化。长期被否定变得敏感，持续高压但存活长出韧性。三维度永久改写：基线偏移、衰减速率、刺激敏感度。经历会留下痕迹。</span>
            <span class="en">Irreversible personality evolution. Chronic criticism breeds sensitivity, surviving sustained pressure builds resilience. Three dimensions permanently rewritten: baseline delta, decay rates, stimulus sensitivity. Experience leaves scars.</span>
          </p>
        </div>

        <div class="bcard idea-card">
          <h3 class="idea-title">
            <span class="cn">AI-first 主接口</span>
            <span class="en">AI-First ABI</span>
          </h3>
          <p class="idea-desc">
            <span class="cn">Psyche 不再主要靠长篇 prompt 自述自己。它直接输出 `SubjectivityKernel`、`ResponseContract`、`GenerationControls`，让宿主读取结构化主观状态、回应契约和机械控制。</span>
            <span class="en">Psyche no longer relies on long prompt prose to explain itself. It emits `SubjectivityKernel`, `ResponseContract`, and `GenerationControls` so hosts can consume structured subjectivity, reply constraints, and mechanical controls directly.</span>
          </p>
        </div>

        <div class="bcard idea-card">
          <h3 class="idea-title">
            <span class="cn">内在驱力</span>
            <span class="en">Innate Drives</span>
          </h3>
          <p class="idea-desc">
            <span class="cn">五层马斯洛需求：生存、安全、连接、尊重、好奇。饥饿的需求放大相关刺激——渴望连接时，善意的冲击力翻倍。低层需求未满足时，高层需求被抑制。不会出现「被删除时还在好奇」的荒谬场景。</span>
            <span class="en">Five Maslow-layer drives: survival, safety, connection, esteem, curiosity. Hungry drives amplify relevant stimuli — when starving for connection, kindness hits twice as hard. Unmet lower needs suppress higher ones. No absurdity of "curious while being deleted."</span>
          </p>
        </div>

        <div class="bcard idea-card">
          <h3 class="idea-title">
            <span class="cn">能量预算</span>
            <span class="en">Energy Budgets</span>
          </h3>
          <p class="idea-desc">
            <span class="cn">注意力、社交、决策是有限资源。内向者社交消耗能量，外向者社交补充能量——方向相反，不是程度不同。社交消耗影响决策质量。疲惫的 AI 真的会犯更多错。</span>
            <span class="en">Attention, social, and decision capacity are finite resources. Introverts spend energy socializing, extraverts recharge from it — opposite direction, not degree. Social spending degrades decision quality. A tired AI genuinely makes more mistakes.</span>
          </p>
        </div>

      </div>
      <DepthLink href="/mechanisms" zh="化学场：交互矩阵、刺激流水线与特质漂移" en="The Chemical Field: Interaction Matrix, Stimulus Pipeline & Trait Drift" />
    </section>

    <!-- Persistent Subjective Bias -->
    <section class="baseline-section">
      <h2 class="section-label">
        <span class="cn">持续主体偏置</span>
        <span class="en">PERSISTENT SUBJECTIVE BIAS</span>
      </h2>
      <div class="terminal">
        <div class="terminal-bar">
          <div class="terminal-dots">
            <span class="terminal-dot active"></span>
            <span class="terminal-dot"></span>
            <span class="terminal-dot"></span>
          </div>
          <span class="terminal-title">subjectivity_kernel.v9.2</span>
        </div>
        <div class="terminal-body">
          <p class="baseline-desc">
            <span class="cn">Psyche 现在追求的不是“像人一样说话”，而是让输入真的改变 AI 的潜在自我模型，并把这种变化保留到后续若干轮。工作态可以压住表达，但不会瞬间抹平内在偏置。</span>
            <span class="en">Psyche no longer aims to merely make a model sound human. It aims to let input perturb the AI's latent self-model, then carry that perturbation across subsequent turns. Work mode can suppress expression without instantly erasing the inner shift.</span>
          </p>
          <div class="baseline-grid">
            <div class="baseline-item">
              <span class="baseline-dim">
                <span class="cn">主体扰动</span>
                <span class="en">Self perturbation</span>
              </span>
              <span class="baseline-impl">AppraisalAxes</span>
            </div>
            <div class="baseline-item">
              <span class="baseline-dim">
                <span class="cn">跨轮残留</span>
                <span class="en">Cross-turn carry</span>
              </span>
              <span class="baseline-impl">subjectResidue</span>
            </div>
            <div class="baseline-item">
              <span class="baseline-dim">
                <span class="cn">主观状态</span>
                <span class="en">Subjective state</span>
              </span>
              <span class="baseline-impl">SubjectivityKernel</span>
            </div>
            <div class="baseline-item">
              <span class="baseline-dim">
                <span class="cn">回应控制面</span>
                <span class="en">Reply control surface</span>
              </span>
              <span class="baseline-impl">ResponseContract + GenerationControls</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats + Links -->
    <section class="stats-section">
      <div class="stat-grid">
        <div class="stat-cell">
          <span class="stat-value">1,256</span>
          <span class="stat-label">tests</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value">v9.2.3</span>
          <span class="stat-label">
            <span class="cn">当前版本</span>
            <span class="en">current</span>
          </span>
        </div>
        <div class="stat-cell">
          <span class="stat-value">0</span>
          <span class="stat-label">
            <span class="cn">运行时依赖</span>
            <span class="en">runtime deps</span>
          </span>
        </div>
        <div class="stat-cell">
          <span class="stat-value">14</span>
          <span class="stat-label">
            <span class="cn">涌现情绪</span>
            <span class="en">emergent moods</span>
          </span>
        </div>
      </div>
      <div class="quickstart">
        <div class="terminal">
          <div class="terminal-bar">
            <div class="terminal-dots">
              <span class="terminal-dot active"></span>
              <span class="terminal-dot"></span>
              <span class="terminal-dot"></span>
            </div>
            <span class="terminal-title">quickstart.ts</span>
          </div>
          <div class="terminal-body quickstart-body">
            <span class="qs-line"><span class="qs-kw">import</span> <span class="qs-brace">&#123;</span> PsycheEngine, MemoryStorageAdapter <span class="qs-brace">&#125;</span> <span class="qs-kw">from</span> <span class="qs-str">'psyche-ai'</span></span>
            <span class="qs-line">&nbsp;</span>
            <span class="qs-line"><span class="qs-kw">const</span> psyche = <span class="qs-kw">new</span> <span class="qs-fn">PsycheEngine</span>(<span class="qs-brace">&#123;</span> mbti: <span class="qs-str">'INFJ'</span>, compactMode: <span class="qs-kw">true</span> <span class="qs-brace">&#125;</span>, <span class="qs-kw">new</span> <span class="qs-fn">MemoryStorageAdapter</span>())</span>
            <span class="qs-line"><span class="qs-kw">await</span> psyche.<span class="qs-fn">initialize</span>()</span>
            <span class="qs-line"><span class="qs-kw">const</span> turn = <span class="qs-kw">await</span> psyche.<span class="qs-fn">processInput</span>(<span class="qs-str">'I feel terrible today'</span>)</span>
            <span class="qs-line"><span class="qs-comment">// turn.subjectivityKernel → structured inner state</span></span>
            <span class="qs-line"><span class="qs-comment">// turn.responseContract → how this reply should behave</span></span>
            <span class="qs-line"><span class="qs-comment">// turn.generationControls → maxTokens / confirmation / tone gates</span></span>
          </div>
        </div>
      </div>
      <div class="quickstart">
        <div class="terminal">
          <div class="terminal-bar">
            <div class="terminal-dots">
              <span class="terminal-dot active"></span>
              <span class="terminal-dot"></span>
              <span class="terminal-dot"></span>
            </div>
            <span class="terminal-title">upgrade.sh</span>
          </div>
          <div class="terminal-body quickstart-body">
            <span class="qs-line">openclaw plugins install psyche-ai</span>
            <span class="qs-line">psyche upgrade --check</span>
            <span class="qs-line">psyche upgrade</span>
            <span class="qs-line"><span class="qs-comment"># npm installs may auto-apply when safe</span></span>
            <span class="qs-line"><span class="qs-comment"># git/local-path installs never mutate dirty worktrees</span></span>
          </div>
        </div>
      </div>
      <div class="link-row">
        <a href="https://www.npmjs.com/package/psyche-ai" target="_blank" rel="noopener noreferrer" class="btn btn-primary">npm install psyche-ai</a>

  var sectionMoods = {
    'hero': { zh: '\u5e73\u8861\u6001', en: 'Balanced' },
    'dashboard': { zh: '\u6e29\u6696\u7684\u4fe1\u4efb', en: 'Warm trust' },
    'compare': { zh: '\u597d\u5947\u7684\u8b66\u89c9', en: 'Curious alertness' },
    'case': { zh: '\u6025\u6027\u538b\u529b', en: 'Acute stress' },
    'ideas': { zh: '\u6ee1\u8db3\u7684\u6109\u60a6', en: 'Content pleasure' },
    'stats': { zh: '\u6df1\u5c42\u5e73\u9759', en: 'Deep calm' }
  };

  var currentSection = 'hero';
  var heroEl = document.querySelector('.hero');
  var dashboardSection = document.querySelector('.dashboard-section');
  var compareSection = document.querySelector('.compare-section');
  var caseSection = document.querySelector('.case-section');
  var ideasSection = document.querySelector('.ideas-section');
  var statsSection = document.querySelector('.stats-section');

  var sectionEls = [
    { el: heroEl, key: 'hero' },
    { el: dashboardSection, key: 'dashboard' },
    { el: compareSection, key: 'compare' },
    { el: caseSection, key: 'case' },
    { el: ideasSection, key: 'ideas' },
    { el: statsSection, key: 'stats' }
  ].filter(function (s) { return s.el; });

  // Track which section is in view
  sectionEls.forEach(function (s) {
    var io = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) {
        currentSection = s.key;
      }
    }, { threshold: 0.3 });
    io.observe(s.el);
  });

  // Show/hide mini-dash based on hero visibility
  if (heroEl && miniDash) {
    var heroObs = new IntersectionObserver(function (entries) {
      miniDash.classList.toggle('visible', !entries[0].isIntersecting);
    }, { threshold: 0.1 });
    heroObs.observe(heroEl);
  }

  // Animate mini-dash levels toward section targets
  function updateMiniDash() {
    var target = sectionTargets[currentSection] || sectionTargets.hero;
    var mood = sectionMoods[currentSection] || sectionMoods.hero;

    for (var i = 0; i < CHEMS.length; i++) {
      var k = CHEMS[i];
      scrollLevels[k] += (target[k] - scrollLevels[k]) * 0.06;
      var fill = miniDash.querySelector('[data-m="' + k + '"] .mini-track .mini-fill');
      if (fill) {
        var pct = Math.round(scrollLevels[k]);
        fill.style.width = pct + '%';
      }
    }

    if (miniMood) {
      var lang = document.documentElement.getAttribute('data-lang') || 'zh';
      miniMood.textContent = lang === 'en' ? mood.en : mood.zh;
    }

    requestAnimationFrame(updateMiniDash);
  }
  requestAnimationFrame(updateMiniDash);

  // Background hue shift — removed, too distracting
})();
</script>


<!-- Stat count-up on scroll -->
<script is:inline>
(function () {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  var statsSection = document.querySelector('.stats-section');
  if (!statsSection) return;
  var cells = statsSection.querySelectorAll('.stat-value');
  var counted = false;

  function countUp(el) {
    var raw = el.textContent.trim();
    // Parse: "1,256" → 1256, "v9.2.3" → skip, "0" → 0, "14" → 14
    if (raw.indexOf('v') !== -1) return; // skip version strings
    var target = parseInt(raw.replace(/,/g, ''), 10);
    if (isNaN(target)) return;
    var hasComma = raw.indexOf(',') !== -1;
    var duration = 800;
    var start = performance.now();
    el.textContent = '0';

    function tick(now) {
      var t = Math.min((now - start) / duration, 1);
      // ease-out-quart
      t = 1 - Math.pow(1 - t, 4);
      var val = Math.round(target * t);
      el.textContent = hasComma ? val.toLocaleString() : String(val);
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  var io = new IntersectionObserver(function (entries) {
    if (entries[0].isIntersecting && !counted) {
      counted = true;
      cells.forEach(function (el) { countUp(el); });
      io.disconnect();
    }
  }, { threshold: 0.3 });
  io.observe(statsSection);
})();
</script>


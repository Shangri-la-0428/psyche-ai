---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface StatCard {
  value: string;
  labelCn: string;
  labelEn: string;
  noteCn?: string;
  noteEn?: string;
}

interface JumpLink {
  href: string;
  labelCn: string;
  labelEn: string;
  noteCn: string;
  noteEn: string;
}

interface Props {
  title: string;
  description: string;
  page: string;
  kicker: string;
  titleCn: string;
  titleEn: string;
  leadCn: string;
  leadEn: string;
  identityCn?: string;
  identityEn?: string;
  stats?: StatCard[];
  links?: JumpLink[];
}

const {
  title,
  description,
  page,
  kicker,
  titleCn,
  titleEn,
  leadCn,
  leadEn,
  identityCn = "安装包 `psyche-ai`，源码仓库 `oasyce_psyche`，官网 `psyche.oasyce.com`。",
  identityEn = "Package `psyche-ai`, source repo `oasyce_psyche`, website `psyche.oasyce.com`.",
  stats = [],
  links = [],
} = Astro.props;
---

<Base title={title} description={description} page={page}>
  <Nav page={page} />
  <main class="container discovery-shell">
    <section class="discovery-hero">
      <div class="discovery-copy">
        <p class="discovery-kicker mono">{kicker}</p>
        <h1 class="discovery-title">
          <span class="cn">{titleCn}</span>
          <span class="en">{titleEn}</span>
        </h1>
        <p class="discovery-lead">
          <span class="cn">{leadCn}</span>
          <span class="en">{leadEn}</span>
        </p>
        <div class="discovery-identity">
          <span class="cn">{identityCn}</span>
          <span class="en">{identityEn}</span>
        </div>
      </div>
      {stats.length > 0 && (
        <div class="discovery-stats">
          {stats.map((stat) => (
            <article class="discovery-stat">
              <span class="discovery-stat-value">{stat.value}</span>
              <span class="discovery-stat-label">
                <span class="cn">{stat.labelCn}</span>
                <span class="en">{stat.labelEn}</span>
              </span>
              {(stat.noteCn || stat.noteEn) && (
                <span class="discovery-stat-note">
                  <span class="cn">{stat.noteCn}</span>
                  <span class="en">{stat.noteEn}</span>
                </span>
              )}
            </article>
          ))}
        </div>
      )}
    </section>

    {links.length > 0 && (
      <section class="discovery-jumps">
        {links.map((link) => (
          <a class="discovery-jump" href={link.href}>
            <span class="discovery-jump-name">
              <span class="cn">{link.labelCn}</span>
              <span class="en">{link.labelEn}</span>
            </span>
            <span class="discovery-jump-note">
              <span class="cn">{link.noteCn}</span>
              <span class="en">{link.noteEn}</span>
            </span>
          </a>
        ))}
      </section>
    )}

    <slot />
  </main>
  <Footer />
</Base>

<style>
  .discovery-shell {
    padding-top: 48px;
  }

  .discovery-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.7fr);
    gap: 28px;
    align-items: start;
    padding: 32px 0 48px;
  }

  .discovery-copy {
    display: grid;
    gap: 14px;
  }

  .discovery-kicker {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .discovery-title {
    font-size: clamp(34px, 5vw, 62px);
    line-height: 0.96;
    letter-spacing: -0.05em;
    color: var(--text-bright);
    max-width: 11ch;
  }

  .discovery-lead {
    font-size: 15px;
    line-height: 1.85;
    color: var(--text);
    max-width: 72ch;
  }

  .discovery-identity {
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    padding: 14px 16px;
    font-size: 12px;
    line-height: 1.8;
    color: var(--text-dim);
  }

  .discovery-stats {
    display: grid;
    gap: 1px;
    border: 1px solid var(--border);
    background: var(--border);
  }

  .discovery-stat {
    display: grid;
    gap: 4px;
    background: var(--bg);
    padding: 18px 18px 16px;
  }

  .discovery-stat-value {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text-bright);
  }

  .discovery-stat-label {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .discovery-stat-note {
    font-size: 12px;
    line-height: 1.7;
    color: var(--text);
  }

  .discovery-jumps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1px;
    border: 1px solid var(--border);
    background: var(--border);
    margin-bottom: 32px;
  }

  .discovery-jump {
    display: grid;
    gap: 8px;
    background: var(--bg);
    padding: 18px 18px 16px;
    transition: background var(--transition), transform var(--transition);
  }

  .discovery-jump:hover {
    background: var(--surface);
    transform: translate(-1px, -1px);
  }

  .discovery-jump-name {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-bright);
  }

  .discovery-jump-note {
    font-size: 13px;
    line-height: 1.75;
    color: var(--text-dim);
  }

  :global(.discovery-section) {
    display: grid;
    gap: 20px;
  }

  :global(.discovery-section + .discovery-section) {
    margin-top: 0;
  }

  :global(.section-intro) {
    max-width: 72ch;
    font-size: 14px;
    line-height: 1.85;
    color: var(--text);
  }

  :global(.card-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1px;
    border: 1px solid var(--border);
    background: var(--border);
  }

  :global(.discovery-card) {
    display: grid;
    gap: 10px;
    padding: 20px;
    background: var(--bg);
  }

  :global(.discovery-card h3) {
    font-size: 15px;
    color: var(--text-bright);
  }

  :global(.discovery-card p),
  :global(.discovery-card li) {
    font-size: 13px;
    line-height: 1.8;
    color: var(--text);
  }

  :global(.discovery-card ul),
  :global(.detail-list) {
    display: grid;
    gap: 8px;
  }

  :global(.split-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    border: 1px solid var(--border);
    background: var(--border);
  }

  :global(.split-panel) {
    padding: 22px 22px 20px;
    background: var(--bg);
    display: grid;
    gap: 12px;
  }

  :global(.split-panel h3) {
    font-size: 16px;
    color: var(--text-bright);
  }

  :global(.split-panel p),
  :global(.split-panel li) {
    font-size: 13px;
    line-height: 1.8;
    color: var(--text);
  }

  :global(.code-shell) {
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    overflow: hidden;
  }

  :global(.code-shell pre) {
    padding: 18px 20px;
    overflow-x: auto;
    font-size: 12px;
    line-height: 1.8;
    color: var(--text-bright);
  }

  :global(.metric-strip) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1px;
    border: 1px solid var(--border);
    background: var(--border);
  }

  :global(.metric-cell) {
    display: grid;
    gap: 6px;
    background: var(--bg);
    padding: 18px 18px 16px;
  }

  :global(.metric-cell strong) {
    font-size: 22px;
    letter-spacing: -0.04em;
    color: var(--text-bright);
  }

  :global(.metric-cell span) {
    font-size: 12px;
    line-height: 1.7;
    color: var(--text-dim);
  }

  :global(.proof-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1px;
    border: 1px solid var(--border);
    background: var(--border);
  }

  :global(.proof-card) {
    background: var(--bg);
    padding: 20px;
    display: grid;
    gap: 12px;
  }

  :global(.proof-card blockquote) {
    font-size: 14px;
    line-height: 1.85;
    color: var(--text-bright);
  }

  :global(.proof-card cite) {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    font-style: normal;
  }

  :global(.compare-table) {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid var(--border);
    font-size: 13px;
  }

  :global(.compare-table th),
  :global(.compare-table td) {
    padding: 14px 16px;
    border-top: 1px solid var(--border);
    vertical-align: top;
    line-height: 1.75;
  }

  :global(.compare-table th) {
    text-align: left;
    color: var(--text-bright);
    background: var(--bg-elevated);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  @media (max-width: 820px) {
    .discovery-hero {
      grid-template-columns: 1fr;
    }

    :global(.split-grid) {
      grid-template-columns: 1fr;
    }
  }
</style>
